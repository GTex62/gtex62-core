core_id = "gtex62-core"
version = "0.1.0"

[paths]
config_root = "__RUNTIME_ROOT__"
data_root = "__HOME__/.local/share/gtex62-core"
cache_root = "__HOME__/.cache/gtex62-core"
suites_root = "__HOME__/.config/conky"

[registry]
suites_dir = "suites"
profiles_dir = "profiles"
overrides_dir = "overrides"
state_dir = "state"

[doctor]
enabled = true

[launcher]
default_suite = "osa"
allow_legacy_suites = true
