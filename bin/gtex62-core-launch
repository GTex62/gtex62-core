#!/usr/bin/env bash
set -euo pipefail

CORE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SUITE_ID="osa"
if [[ "${1:-}" == "--suite" && -n "${2:-}" ]]; then
  SUITE_ID="$2"
elif [[ -n "${1:-}" ]]; then
  SUITE_ID="$1"
fi

resolve_root() {
  local current="$1"
  local legacy="$2"
  local current_default="$3"
  local legacy_default="$4"
  if [[ -n "$current" ]]; then
    printf "%s\n" "$current"
  elif [[ -n "$legacy" ]]; then
    printf "%s\n" "$legacy"
  elif [[ -e "$legacy_default" && ! -e "$current_default" ]]; then
    printf "%s\n" "$legacy_default"
  else
    printf "%s\n" "$current_default"
  fi
}

CONFIG_ROOT="$(resolve_root "${GTEX62_CONFIG_DIR:-}" "${GTEX62_CONKY_CONFIG_DIR:-}" "$HOME/.config/gtex62-core" "$HOME/.config/gtex62-conky")"
CORE_TOML="$CONFIG_ROOT/core.toml"
LEGACY_ENGINE_TOML="$CONFIG_ROOT/engine.toml"
SUITE_TOML="$CONFIG_ROOT/suites/${SUITE_ID}.toml"

if [[ ! -f "$SUITE_TOML" ]]; then
  echo "Suite config not found: $SUITE_TOML" >&2
  exit 1
fi

parse_toml_value() {
  local path="$1"
  local key="$2"
  [[ -f "$path" ]] || return 0
  awk -F= -v key="$key" '
    $0 ~ "^[[:space:]]*" key "[[:space:]]*=" {
      v=$2
      sub(/^[[:space:]]+/, "", v)
      sub(/[[:space:]]+$/, "", v)
      gsub(/^"|"$/, "", v)
      print v
      exit
    }
  ' "$path"
}

parse_toml_section_value() {
  local path="$1"
  local section="$2"
  local key="$3"
  [[ -f "$path" ]] || return 0
  awk -F= -v section="$section" -v key="$key" '
    /^[[:space:]]*\[/ {
      in_section = ($0 == "[" section "]")
      next
    }
    in_section && $0 ~ "^[[:space:]]*" key "[[:space:]]*=" {
      v=$2
      sub(/^[[:space:]]+/, "", v)
      sub(/[[:space:]]+$/, "", v)
      gsub(/^"|"$/, "", v)
      print v
      exit
    }
  ' "$path"
}

CACHE_ROOT="$(resolve_root "${GTEX62_CACHE_DIR:-}" "${GTEX62_CONKY_CACHE_DIR:-}" "$HOME/.cache/gtex62-core" "$HOME/.cache/gtex62-conky")"
if [[ -f "$CORE_TOML" ]]; then
  CACHE_ROOT="$(parse_toml_section_value "$CORE_TOML" paths cache_root || true)"
elif [[ -f "$LEGACY_ENGINE_TOML" ]]; then
  CACHE_ROOT="$(parse_toml_section_value "$LEGACY_ENGINE_TOML" paths cache_root || true)"
fi
CACHE_ROOT="${CACHE_ROOT:-$(resolve_root "" "" "$HOME/.cache/gtex62-core" "$HOME/.cache/gtex62-conky")}"

SUITE_DIR="$(parse_toml_value "$SUITE_TOML" suite_repo)"
WEATHER_PROFILE="$(parse_toml_section_value "$SUITE_TOML" profiles weather || true)"
AIR_PROFILE="$(parse_toml_section_value "$SUITE_TOML" profiles air || true)"
SOLAR_PROFILE="$(parse_toml_section_value "$SUITE_TOML" profiles solar || true)"
AVIATION_PROFILE="$(parse_toml_section_value "$SUITE_TOML" profiles aviation || true)"
SYSTEM_PROFILE="$(parse_toml_section_value "$SUITE_TOML" profiles system || true)"
CALENDAR_PROFILE="$(parse_toml_section_value "$SUITE_TOML" profiles calendar || true)"
TIME_PROFILE="$(parse_toml_section_value "$SUITE_TOML" profiles time || true)"
ASTRO_PROFILE="$(parse_toml_section_value "$SUITE_TOML" profiles astro || true)"
NETWORK_PROFILE="$(parse_toml_section_value "$SUITE_TOML" profiles network || true)"
CONNECTIVITY_PROFILE="$(parse_toml_section_value "$SUITE_TOML" profiles connectivity || true)"
PFSENSE_PROFILE="$(parse_toml_section_value "$SUITE_TOML" profiles pfsense || true)"
WEATHER_PROFILE="${WEATHER_PROFILE:-home}"
AIR_PROFILE="${AIR_PROFILE:-home}"
SOLAR_PROFILE="${SOLAR_PROFILE:-home}"
AVIATION_PROFILE="${AVIATION_PROFILE:-home}"
SYSTEM_PROFILE="${SYSTEM_PROFILE:-local}"
CALENDAR_PROFILE="${CALENDAR_PROFILE:-local}"
TIME_PROFILE="${TIME_PROFILE:-local}"
ASTRO_PROFILE="${ASTRO_PROFILE:-home}"
NETWORK_PROFILE="${NETWORK_PROFILE:-local}"
CONNECTIVITY_PROFILE="${CONNECTIVITY_PROFILE:-default}"
PFSENSE_PROFILE="${PFSENSE_PROFILE:-main_router}"

WEATHER_PROFILE_TOML="$CONFIG_ROOT/profiles/weather/${WEATHER_PROFILE}.toml"
AIR_PROFILE_TOML="$CONFIG_ROOT/profiles/air/${AIR_PROFILE}.toml"
SOLAR_PROFILE_TOML="$CONFIG_ROOT/profiles/solar/${SOLAR_PROFILE}.toml"
AVIATION_PROFILE_TOML="$CONFIG_ROOT/profiles/aviation/${AVIATION_PROFILE}.toml"
SYSTEM_PROFILE_TOML="$CONFIG_ROOT/profiles/system/${SYSTEM_PROFILE}.toml"
CALENDAR_PROFILE_TOML="$CONFIG_ROOT/profiles/calendar/${CALENDAR_PROFILE}.toml"
TIME_PROFILE_TOML="$CONFIG_ROOT/profiles/time/${TIME_PROFILE}.toml"
ASTRO_PROFILE_TOML="$CONFIG_ROOT/profiles/astro/${ASTRO_PROFILE}.toml"
NETWORK_PROFILE_TOML="$CONFIG_ROOT/profiles/network/${NETWORK_PROFILE}.toml"
PFSENSE_PROFILE_TOML="$CONFIG_ROOT/profiles/pfsense/${PFSENSE_PROFILE}.toml"
WEATHER_TTL="$(parse_toml_section_value "$WEATHER_PROFILE_TOML" request cache_ttl_sec || true)"
AIR_TTL="$(parse_toml_section_value "$AIR_PROFILE_TOML" cache ttl_sec || true)"
SOLAR_TTL="$(parse_toml_section_value "$SOLAR_PROFILE_TOML" cache refresh_sec || true)"
AVIATION_METAR_TTL="$(parse_toml_section_value "$AVIATION_PROFILE_TOML" cache metar_ttl_sec || true)"
AVIATION_TAF_TTL="$(parse_toml_section_value "$AVIATION_PROFILE_TOML" cache taf_ttl_sec || true)"
SYSTEM_TTL="$(parse_toml_section_value "$SYSTEM_PROFILE_TOML" cache refresh_sec || true)"
CALENDAR_TTL="$(parse_toml_section_value "$CALENDAR_PROFILE_TOML" cache refresh_sec || true)"
TIME_TTL="$(parse_toml_section_value "$TIME_PROFILE_TOML" cache refresh_sec || true)"
ASTRO_TTL="$(parse_toml_section_value "$ASTRO_PROFILE_TOML" cache refresh_sec || true)"
NETWORK_TTL="$(parse_toml_section_value "$NETWORK_PROFILE_TOML" cache refresh_sec || true)"
PFSENSE_TTL="$(parse_toml_value "$PFSENSE_PROFILE_TOML" cache_ttl_sec || true)"
NET_TTL="${GTEX62_OSA_NET_CACHE_TTL:-1}"
ORB_TTL="${GTEX62_OSA_ORB_CACHE_TTL:-60}"
WEATHER_TTL="${WEATHER_TTL:-300}"
AIR_TTL="${AIR_TTL:-900}"
SOLAR_TTL="${SOLAR_TTL:-300}"
AVIATION_METAR_TTL="${AVIATION_METAR_TTL:-600}"
AVIATION_TAF_TTL="${AVIATION_TAF_TTL:-600}"
SYSTEM_TTL="${SYSTEM_TTL:-1}"
CALENDAR_TTL="${CALENDAR_TTL:-300}"
TIME_TTL="${TIME_TTL:-1}"
ASTRO_TTL="${ASTRO_TTL:-60}"
NETWORK_TTL="${NETWORK_TTL:-5}"
PFSENSE_TTL="${PFSENSE_TTL:-5}"
AVIATION_TTL="$AVIATION_METAR_TTL"
if (( AVIATION_TAF_TTL < AVIATION_TTL )); then
  AVIATION_TTL="$AVIATION_TAF_TTL"
fi

export GTEX62_CORE_DIR="$CORE_DIR"
export GTEX62_CONFIG_DIR="$CONFIG_ROOT"
export GTEX62_CACHE_DIR="$CACHE_ROOT"
export GTEX62_SUITE_ID="$SUITE_ID"
export GTEX62_CONKY_ENGINE_DIR="$CORE_DIR"
export GTEX62_CONKY_CONFIG_DIR="$CONFIG_ROOT"
export GTEX62_CONKY_CACHE_DIR="$CACHE_ROOT"
export GTEX62_CONKY_SUITE_ID="$SUITE_ID"
export CONKY_SUITE_DIR="$SUITE_DIR"

LOCKS_DIR="$CACHE_ROOT/runtime/locks"
PIDS_DIR="$CACHE_ROOT/runtime/pids"
STAMPS_DIR="$CACHE_ROOT/runtime/stamps"
mkdir -p \
  "$CACHE_ROOT/shared/weather/$WEATHER_PROFILE" \
  "$CACHE_ROOT/shared/air/$AIR_PROFILE" \
  "$CACHE_ROOT/shared/solar/$SOLAR_PROFILE" \
  "$CACHE_ROOT/shared/aviation/$AVIATION_PROFILE" \
  "$CACHE_ROOT/shared/system/$SYSTEM_PROFILE" \
  "$CACHE_ROOT/shared/calendar/$CALENDAR_PROFILE" \
  "$CACHE_ROOT/shared/time/$TIME_PROFILE" \
  "$CACHE_ROOT/shared/astro/$ASTRO_PROFILE" \
  "$CACHE_ROOT/shared/network/$NETWORK_PROFILE" \
  "$CACHE_ROOT/shared/connectivity/$CONNECTIVITY_PROFILE" \
  "$CACHE_ROOT/shared/pfsense/$PFSENSE_PROFILE" \
  "$CACHE_ROOT/suites/$SUITE_ID/net" \
  "$CACHE_ROOT/suites/$SUITE_ID/orb" \
  "$LOCKS_DIR" \
  "$PIDS_DIR" \
  "$STAMPS_DIR" \
  "$CACHE_ROOT/tmp"

CONKY_PID_FILE="$PIDS_DIR/${SUITE_ID}-conky.pid"
WEATHER_LOOP_PID_FILE="$PIDS_DIR/${SUITE_ID}-weather-refresh.pid"
AIR_LOOP_PID_FILE="$PIDS_DIR/${SUITE_ID}-air-refresh.pid"
SOLAR_LOOP_PID_FILE="$PIDS_DIR/${SUITE_ID}-solar-refresh.pid"
AVIATION_LOOP_PID_FILE="$PIDS_DIR/${SUITE_ID}-aviation-refresh.pid"
SYSTEM_LOOP_PID_FILE="$PIDS_DIR/${SUITE_ID}-system-refresh.pid"
CALENDAR_LOOP_PID_FILE="$PIDS_DIR/${SUITE_ID}-calendar-refresh.pid"
TIME_LOOP_PID_FILE="$PIDS_DIR/${SUITE_ID}-time-refresh.pid"
ASTRO_LOOP_PID_FILE="$PIDS_DIR/${SUITE_ID}-astro-refresh.pid"
NETWORK_LOOP_PID_FILE="$PIDS_DIR/${SUITE_ID}-network-refresh.pid"
CONNECTIVITY_LOOP_PID_FILE="$PIDS_DIR/${SUITE_ID}-connectivity-refresh.pid"
PFSENSE_LOOP_PID_FILE="$PIDS_DIR/${SUITE_ID}-pfsense-refresh.pid"
NET_LOOP_PID_FILE="$PIDS_DIR/${SUITE_ID}-net-refresh.pid"
ORB_LOOP_PID_FILE="$PIDS_DIR/${SUITE_ID}-orb-refresh.pid"
LAUNCHER_PID_FILE="$PIDS_DIR/${SUITE_ID}-launcher.pid"
WEATHER_STAMP="$STAMPS_DIR/weather-${WEATHER_PROFILE}.stamp"
AIR_STAMP="$STAMPS_DIR/air-${AIR_PROFILE}.stamp"
SOLAR_STAMP="$STAMPS_DIR/solar-${SOLAR_PROFILE}.stamp"
AVIATION_STAMP="$STAMPS_DIR/aviation-${AVIATION_PROFILE}.stamp"
SYSTEM_STAMP="$STAMPS_DIR/system-${SYSTEM_PROFILE}.stamp"
CALENDAR_STAMP="$STAMPS_DIR/calendar-${CALENDAR_PROFILE}.stamp"
TIME_STAMP="$STAMPS_DIR/time-${TIME_PROFILE}.stamp"
ASTRO_STAMP="$STAMPS_DIR/astro-${ASTRO_PROFILE}.stamp"
NETWORK_STAMP="$STAMPS_DIR/network-${NETWORK_PROFILE}.stamp"
CONNECTIVITY_STAMP="$STAMPS_DIR/connectivity-${CONNECTIVITY_PROFILE}.stamp"
PFSENSE_STAMP="$STAMPS_DIR/pfsense-${PFSENSE_PROFILE}.stamp"
NET_STAMP="$STAMPS_DIR/${SUITE_ID}-net-cache.stamp"
ORB_STAMP="$STAMPS_DIR/${SUITE_ID}-orb-cache.stamp"

echo $$ > "$LAUNCHER_PID_FILE"
LOOP_PIDS=()
LOOP_PID_FILES=()

cleanup_pidfile() {
  local file="$1"
  if [[ -f "$file" ]]; then
    local pid
    pid="$(cat "$file" 2>/dev/null || true)"
    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null || true
    fi
    rm -f "$file"
  fi
}

remove_pidfile_if_value() {
  local file="$1"
  local expected="$2"
  local current=""
  [[ -n "$expected" && -f "$file" ]] || return 0
  current="$(cat "$file" 2>/dev/null || true)"
  if [[ "$current" == "$expected" ]]; then
    rm -f "$file"
  fi
}

cleanup() {
  local i pid pid_file
  for pid in "${LOOP_PIDS[@]:-}"; do
    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null || true
    fi
  done
  for i in "${!LOOP_PID_FILES[@]}"; do
    pid_file="${LOOP_PID_FILES[$i]}"
    pid="${LOOP_PIDS[$i]:-}"
    remove_pidfile_if_value "$pid_file" "$pid"
  done
  # Clean up all conky PID files (single-chassis or multi-chassis)
  for i in "${!CONKY_PIDS[@]:-}"; do
    remove_pidfile_if_value "${CONKY_PID_FILES[$i]:-}" "${CONKY_PIDS[$i]:-}"
  done
  remove_pidfile_if_value "$CONKY_PID_FILE" "${CONKY_PID:-}"
  remove_pidfile_if_value "$LAUNCHER_PID_FILE" "$$"
}
trap cleanup EXIT INT TERM

cleanup_pidfile "$WEATHER_LOOP_PID_FILE"
cleanup_pidfile "$AIR_LOOP_PID_FILE"
cleanup_pidfile "$SOLAR_LOOP_PID_FILE"
cleanup_pidfile "$AVIATION_LOOP_PID_FILE"
cleanup_pidfile "$SYSTEM_LOOP_PID_FILE"
cleanup_pidfile "$CALENDAR_LOOP_PID_FILE"
cleanup_pidfile "$TIME_LOOP_PID_FILE"
cleanup_pidfile "$ASTRO_LOOP_PID_FILE"
cleanup_pidfile "$NETWORK_LOOP_PID_FILE"
cleanup_pidfile "$CONNECTIVITY_LOOP_PID_FILE"
cleanup_pidfile "$PFSENSE_LOOP_PID_FILE"
cleanup_pidfile "$NET_LOOP_PID_FILE"
cleanup_pidfile "$ORB_LOOP_PID_FILE"

run_locked() {
  local name="$1"
  local stamp="$2"
  shift 2
  local lock_dir="$LOCKS_DIR/${name}.lock"
  local lock_pid_file="$lock_dir/pid"
  if [[ -d "$lock_dir" ]]; then
    local lock_pid
    lock_pid="$(cat "$lock_pid_file" 2>/dev/null || true)"
    if [[ -z "$lock_pid" ]] || ! kill -0 "$lock_pid" 2>/dev/null; then
      rm -rf "$lock_dir" 2>/dev/null || true
    fi
  fi
  if mkdir "$lock_dir" 2>/dev/null; then
    (
      echo "$BASHPID" > "$lock_pid_file" 2>/dev/null || true
      trap 'rm -rf "$lock_dir" 2>/dev/null || true' EXIT
      "$@"
      date -u +%Y-%m-%dT%H:%M:%SZ > "$stamp"
    )
  fi
}

refresh_loop() {
  local name="$1"
  local interval="$2"
  local stamp="$3"
  local pid_file="$4"
  shift 4
  (
    loop_pid="$BASHPID"
    echo "$loop_pid" > "$pid_file"
    sleep "$interval"
    case "$name" in
      system-*) sleep 0.10 ;;
      time-*) sleep 0.30 ;;
      pfsense-*) sleep 0.50 ;;
      "${SUITE_ID}-net-cache") sleep 0.70 ;;
    esac
    while kill -0 "$CONKY_PID" 2>/dev/null; do
      kill -0 "$CONKY_PID" 2>/dev/null || break
      started_ns=""
      ended_ns=""
      sleep_for=""
      started_ns="$(date +%s%N)"
      run_locked "$name" "$stamp" "$@"
      ended_ns="$(date +%s%N)"
      sleep_for="$(
        awk -v started="$started_ns" -v ended="$ended_ns" -v interval="$interval" 'BEGIN {
          elapsed = (ended - started) / 1000000000
          wait = interval - elapsed
          if (wait < 0.05) wait = 0.05
          printf "%.3f\n", wait
        }'
      )"
      sleep "$sleep_for"
    done
    remove_pidfile_if_value "$pid_file" "$loop_pid"
  ) &
  LOOP_PIDS+=("$!")
  LOOP_PID_FILES+=("$pid_file")
}

initial_refresh() {
  local name="$1"
  local stamp="$2"
  shift 2
  (
    run_locked "$name" "$stamp" "$@"
  ) &
}

# -------------------------------------------------------------------------
# Launch Conky chassis — multi-chassis (suite.toml [[instances]]) or legacy
# -------------------------------------------------------------------------

# Read conf paths from [[instances.chassis]] and [[instances.standalone]] blocks.
# Falls back to the single OSA window if no suite manifest is present.
get_instance_confs() {
  local path="$1"
  [[ -f "$path" ]] || return 0
  awk '
    /^\[\[instances\.(chassis|standalone)\]\]/ { in_block = 1; next }
    /^\[/ { in_block = 0 }
    in_block && /^[[:space:]]*conf[[:space:]]*=/ {
      v = $0; sub(/^[^=]+=/, "", v)
      gsub(/^[[:space:]"]+|[[:space:]"]+$/, "", v)
      print v
    }
  ' "$path"
}

CONKY_PIDS=()
CONKY_PID_FILES=()
SUITE_MANIFEST="$SUITE_DIR/suite.toml"

if [[ -f "$SUITE_MANIFEST" ]] && grep -q '^\[\[instances\.' "$SUITE_MANIFEST" 2>/dev/null; then
  while IFS= read -r conf_rel; do
    [[ -n "$conf_rel" ]] || continue
    conf_abs="$SUITE_DIR/$conf_rel"
    if [[ ! -f "$conf_abs" ]]; then
      echo "Warning: instance conf not found: $conf_abs" >&2
      continue
    fi
    conky -c "$conf_abs" &
    _pid=$!
    _id="$(basename "$conf_rel" .conky.conf)"
    _pid_file="$PIDS_DIR/${SUITE_ID}-${_id}-conky.pid"
    echo "$_pid" > "$_pid_file"
    CONKY_PIDS+=("$_pid")
    CONKY_PID_FILES+=("$_pid_file")
  done < <(get_instance_confs "$SUITE_MANIFEST")
else
  # Legacy single-window fallback (OSA)
  conky -c "$SUITE_DIR/widgets/osa-main.conky.conf" &
  CONKY_PIDS=("$!")
  CONKY_PID_FILES=("$CONKY_PID_FILE")
  echo "${CONKY_PIDS[0]}" > "$CONKY_PID_FILE"
fi

# CONKY_PID: primary process watched by refresh loops
CONKY_PID="${CONKY_PIDS[0]:-}"
[[ -n "$CONKY_PID" ]] && echo "$CONKY_PID" > "$CONKY_PID_FILE"

initial_refresh "weather-${WEATHER_PROFILE}" "$WEATHER_STAMP" "$CORE_DIR/providers/weather/fetch_openweather.sh" "$WEATHER_PROFILE"
initial_refresh "air-${AIR_PROFILE}" "$AIR_STAMP" "$CORE_DIR/providers/air/fetch_air.sh" "$AIR_PROFILE"
initial_refresh "solar-${SOLAR_PROFILE}" "$SOLAR_STAMP" "$CORE_DIR/providers/solar/fetch_solar.sh" "$SOLAR_PROFILE"
initial_refresh "aviation-${AVIATION_PROFILE}" "$AVIATION_STAMP" "$CORE_DIR/providers/aviation/fetch_aviation.sh" "$AVIATION_PROFILE"
initial_refresh "system-${SYSTEM_PROFILE}" "$SYSTEM_STAMP" "$CORE_DIR/providers/system/fetch_system.sh" "$SYSTEM_PROFILE"
initial_refresh "calendar-${CALENDAR_PROFILE}" "$CALENDAR_STAMP" "$CORE_DIR/providers/calendar/fetch_calendar.sh" "$CALENDAR_PROFILE"
initial_refresh "time-${TIME_PROFILE}" "$TIME_STAMP" "$CORE_DIR/providers/time/fetch_time.sh" "$TIME_PROFILE"
initial_refresh "astro-${ASTRO_PROFILE}" "$ASTRO_STAMP" "$CORE_DIR/providers/astro/fetch_astro.sh" "$ASTRO_PROFILE"
initial_refresh "network-${NETWORK_PROFILE}" "$NETWORK_STAMP" "$CORE_DIR/providers/network/fetch_network.sh" "$NETWORK_PROFILE"
initial_refresh "connectivity-${CONNECTIVITY_PROFILE}" "$CONNECTIVITY_STAMP" "$CORE_DIR/providers/connectivity/fetch_connectivity.sh" "$CONNECTIVITY_PROFILE"
initial_refresh "pfsense-${PFSENSE_PROFILE}" "$PFSENSE_STAMP" "$CORE_DIR/providers/pfsense/fetch_pfsense.sh" "$PFSENSE_PROFILE"
[[ -x "$SUITE_DIR/scripts/refresh_net_cache.sh" ]] && \
  initial_refresh "${SUITE_ID}-net-cache" "$NET_STAMP" bash "$SUITE_DIR/scripts/refresh_net_cache.sh"
[[ -x "$SUITE_DIR/scripts/refresh_orb_cache.sh" ]] && \
  initial_refresh "${SUITE_ID}-orb-cache" "$ORB_STAMP" bash "$SUITE_DIR/scripts/refresh_orb_cache.sh"

refresh_loop "weather-${WEATHER_PROFILE}" "$WEATHER_TTL" "$WEATHER_STAMP" "$WEATHER_LOOP_PID_FILE" "$CORE_DIR/providers/weather/fetch_openweather.sh" "$WEATHER_PROFILE"
refresh_loop "air-${AIR_PROFILE}" "$AIR_TTL" "$AIR_STAMP" "$AIR_LOOP_PID_FILE" "$CORE_DIR/providers/air/fetch_air.sh" "$AIR_PROFILE"
refresh_loop "solar-${SOLAR_PROFILE}" "$SOLAR_TTL" "$SOLAR_STAMP" "$SOLAR_LOOP_PID_FILE" "$CORE_DIR/providers/solar/fetch_solar.sh" "$SOLAR_PROFILE"
refresh_loop "aviation-${AVIATION_PROFILE}" "$AVIATION_TTL" "$AVIATION_STAMP" "$AVIATION_LOOP_PID_FILE" "$CORE_DIR/providers/aviation/fetch_aviation.sh" "$AVIATION_PROFILE"
refresh_loop "system-${SYSTEM_PROFILE}" "$SYSTEM_TTL" "$SYSTEM_STAMP" "$SYSTEM_LOOP_PID_FILE" "$CORE_DIR/providers/system/fetch_system.sh" "$SYSTEM_PROFILE"
refresh_loop "calendar-${CALENDAR_PROFILE}" "$CALENDAR_TTL" "$CALENDAR_STAMP" "$CALENDAR_LOOP_PID_FILE" "$CORE_DIR/providers/calendar/fetch_calendar.sh" "$CALENDAR_PROFILE"
refresh_loop "time-${TIME_PROFILE}" "$TIME_TTL" "$TIME_STAMP" "$TIME_LOOP_PID_FILE" "$CORE_DIR/providers/time/fetch_time.sh" "$TIME_PROFILE"
refresh_loop "astro-${ASTRO_PROFILE}" "$ASTRO_TTL" "$ASTRO_STAMP" "$ASTRO_LOOP_PID_FILE" "$CORE_DIR/providers/astro/fetch_astro.sh" "$ASTRO_PROFILE"
refresh_loop "network-${NETWORK_PROFILE}" "$NETWORK_TTL" "$NETWORK_STAMP" "$NETWORK_LOOP_PID_FILE" "$CORE_DIR/providers/network/fetch_network.sh" "$NETWORK_PROFILE"
refresh_loop "pfsense-${PFSENSE_PROFILE}" "$PFSENSE_TTL" "$PFSENSE_STAMP" "$PFSENSE_LOOP_PID_FILE" "$CORE_DIR/providers/pfsense/fetch_pfsense.sh" "$PFSENSE_PROFILE"
[[ -x "$SUITE_DIR/scripts/refresh_net_cache.sh" ]] && \
  refresh_loop "${SUITE_ID}-net-cache" "$NET_TTL" "$NET_STAMP" "$NET_LOOP_PID_FILE" bash "$SUITE_DIR/scripts/refresh_net_cache.sh"
[[ -x "$SUITE_DIR/scripts/refresh_orb_cache.sh" ]] && \
  refresh_loop "${SUITE_ID}-orb-cache" "$ORB_TTL" "$ORB_STAMP" "$ORB_LOOP_PID_FILE" bash "$SUITE_DIR/scripts/refresh_orb_cache.sh"

# Wait for all conky processes; exit when the primary one exits
for _wait_pid in "${CONKY_PIDS[@]:-}"; do
  wait "$_wait_pid" 2>/dev/null || true
  break
done
